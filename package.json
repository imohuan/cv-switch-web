{
  "name": "@axtools/cv-switch-web",
  "version": "1.0.0",
  "description": "Web-based AI tool config manager - like CC Switch for cloud servers",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "bin": {
    "cv-switch-web": "./bin/server.mjs"
  },
  "files": [
    "bin/",
    "backend/dist/",
    "frontend/dist/",
    "README.md"
  ],
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:backend": "pnpm --filter cc-switch-web-backend dev",
    "dev:frontend": "pnpm --filter cc-switch-web-frontend dev",
    "build": "pnpm --filter cc-switch-web-backend build && pnpm --filter cc-switch-web-frontend build",
    "start": "node ./bin/server.mjs start",
    "stop": "node ./bin/server.mjs stop",
    "pack:dry": "npm pack --dry-run",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "smol-toml": "^1.4.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  }
}
